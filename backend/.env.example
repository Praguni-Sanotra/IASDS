# Copy to .env and adjust

# Local MongoDB (recommended for dev)
MONGO_URI=mongodb://127.0.0.1:27017/iasds

# Or MongoDB Atlas (requires network access)
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/iasds

BACKEND_PORT=5001
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
FRONTEND_URL=http://localhost:3000
SCHEDULER_URL=http://localhost:8000

# Redis optional (async schedule jobs only)
REDIS_URL=redis://127.0.0.1:6379
